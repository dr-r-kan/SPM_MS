#!/bin/bash -l

# Quick environment check for both experiment parts on UCL Myriad.

#$ -l h_rt=2:00:0
#$ -l mem=4G
#$ -l tmpfs=20G
#$ -pe smp 1
#$ -l matlab=1
#$ -N ms_smoke
#$ -j y

#Local2Scratch

set -euo pipefail

module load xorg-utils/X11R7.7
module load matlab/full/r2021a/9.10
module list

cd "${TMPDIR}"

: "${PROJECT_ROOT:?PROJECT_ROOT must be exported when submitting}"
: "${LEMON_MANIFEST:?LEMON_MANIFEST must be exported when submitting}"
SMOKE_OUTPUT_DIR=${SMOKE_OUTPUT_DIR:-"${PROJECT_ROOT}/outputs/smoke_test"}

matlab -nodisplay -nosplash -r "try, addpath('${PROJECT_ROOT}'); addpath(fullfile('${PROJECT_ROOT}','scripts')); run_experiment_smoke_tests('manifest_csv','${LEMON_MANIFEST}','output_root','${SMOKE_OUTPUT_DIR}'); catch ME, disp(getReport(ME,'extended')); exit(1); end; exit"
